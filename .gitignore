# ============================================================
# OWASP Inspector — .gitignore
# Ubicar en: owasp-scanner/   (raíz del repositorio)
# ============================================================

# ------------------------------------------------------------
# SECRETOS — Nunca subir al repositorio
# ------------------------------------------------------------
.env
*.env
!.env.example

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Entornos virtuales
venv/
.venv/
env/
ENV/

# Distribución / empaquetado
build/
dist/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ------------------------------------------------------------
# Base de datos
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/

# ------------------------------------------------------------
# IDEs y editores
# ------------------------------------------------------------
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Reportes generados por la app
# ------------------------------------------------------------
exports/
reportes/